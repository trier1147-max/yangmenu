/* 洋菜单 - 历史记录页样式 (Apple Style) */
.history {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx;
}

.history-group {
  padding: 0;
  /* background: var(--color-surface); removed to inherit .card */
  /* border-radius: 48rpx; removed to inherit .card */
  margin-bottom: 32rpx;
}

.history-row {
  position: relative;
  display: flex;
  align-items: center;
  padding: 36rpx 40rpx;
  transition: background 0.3s ease;
}

.history-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  background: var(--color-bg);
  border-radius: 48rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 32rpx;
  flex-shrink: 0;
}

.history-emoji {
  font-size: 48rpx;
}

.history-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  min-width: 0;
  margin-right: 24rpx;
}

.history-title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.history-dishes {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-main);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
}

.ai-tag {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 4rpx 12rpx;
  background: rgba(255, 159, 10, 0.15);
  border-radius: 12rpx;
  flex-shrink: 0;
}

.ai-tag-text {
  font-size: 20rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.history-time {
  font-size: 28rpx;
  color: var(--text-sub);
}

.history-actions {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.history-delete {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: rgba(238, 10, 36, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
}

.divider {
  position: absolute;
  bottom: 0;
  left: 168rpx; /* 与文字左侧对齐 */
  right: 0;
  height: 1px;
  background: rgba(0, 0, 0, 0.05);
}

/* 空状态 */
.empty-state {
  position: absolute;
  top: 45%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.empty-emoji {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-sub);
}
