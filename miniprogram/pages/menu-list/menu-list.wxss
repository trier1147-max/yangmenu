.menu-list {
  --menu-card-bg: rgba(255, 255, 255, 0.52);
  --menu-card-border: rgba(255, 255, 255, 0.52);
  --menu-card-border-soft: rgba(255, 255, 255, 0.26);
  --menu-card-shadow: var(--glass-shadow);
  --menu-accent: var(--color-primary);
  --menu-muted: var(--text-sub);
  min-height: 100vh;
  box-sizing: border-box;
  padding: 20rpx 32rpx;
  padding-bottom: 0;
}

.menu-list__scroll {
  height: calc(100vh - 40rpx);
  box-sizing: border-box;
}

.menu-list__bottom-pad {
  height: calc(180rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
}

.menu-list__loading {
  display: flex;
  justify-content: center;
  padding: 120rpx 0;
}

.menu-list__status {
  margin-bottom: 24rpx;
  padding: 24rpx 28rpx;
  background: var(--menu-card-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border: 1px solid var(--menu-card-border);
  box-shadow: var(--menu-card-shadow);
}

.menu-list__status-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.menu-list__status-emoji {
  font-size: 34rpx;
  line-height: 1;
  transform-origin: center;
  animation: chefBounce 1.8s ease-in-out infinite;
}

.menu-list__status-text {
  font-size: 28rpx;
  color: var(--text-main);
  font-weight: 600;
}

.menu-list__timeout-text {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #b86b00;
}

.menu-list__error {
  padding: 100rpx 32rpx;
  text-align: center;
}

.menu-list__error-text {
  font-size: 32rpx;
  color: var(--text-sub);
}

.menu-list__container {
  padding: 0;
  position: relative;
  min-height: 100vh;
}

.header-card {
  padding: 0;
  overflow: hidden;
  position: relative;
  height: 210rpx;
  margin-bottom: 16rpx;
  border-radius: 48rpx;
  border: 1px solid var(--glass-border);
  box-shadow: var(--menu-card-shadow);
}

.menu-list__thumb {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.thumb-blur-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 68rpx;
  background-color: rgba(255, 255, 255, 0.4);
  background-image: var(--glass-noise);
  backdrop-filter: blur(40px) saturate(150%);
  -webkit-backdrop-filter: blur(40px) saturate(150%);
  display: flex;
  align-items: center;
  padding: 0 28rpx;
  border-top: 1px solid rgba(255, 255, 255, 0.36);
}

.thumb-text {
  color: var(--text-main);
  font-size: 26rpx;
  font-weight: 600;
}

.dish-bubbles {
  display: flex;
  flex-direction: column;
}

.category-section {
  margin: 0 0 16rpx;
  padding: 12rpx 0;
}

.category-collapsed-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.category-chips-wrap {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.category-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  padding: 4rpx 0;
}

.category-row--collapsed {
  flex-wrap: nowrap;
}

.category-expand-fixed {
  flex-shrink: 0;
}

.category-row--wrap {
  flex-wrap: wrap;
  width: 100%;
}

.category-expanded {
  padding: 4rpx 0;
}

.category-chip {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: var(--text-main);
  background: rgba(255, 255, 255, 0.58);
  border: 1px solid rgba(255, 255, 255, 0.65);
  flex-shrink: 0;
  transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
}

.category-chip--sm {
  padding: 8rpx 14rpx;
  font-size: 22rpx;
}

.category-chip--active {
  color: #ffffff;
  background: linear-gradient(135deg, #ff9f0a 0%, #ff7a00 100%);
  border-color: rgba(255, 122, 0, 0.5);
}

.category-chip--expand {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  color: rgba(255, 149, 0, 0.9);
  background: rgba(255, 149, 0, 0.08);
  border: 1px solid rgba(255, 149, 0, 0.25);
}

.category-chip--expand-hover {
  background: rgba(255, 149, 0, 0.15);
  border-color: rgba(255, 149, 0, 0.4);
}

.dish-card {
  padding: 0;
  margin-bottom: 14rpx;
  background: var(--menu-card-bg);
  border: 1px solid var(--menu-card-border);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  box-shadow: var(--menu-card-shadow);
  position: relative;
  transform: translateY(0) scale(1);
  transition:
    transform 0.22s cubic-bezier(0.22, 1, 0.36, 1),
    box-shadow 0.22s ease,
    border-color 0.22s ease;
  will-change: transform, box-shadow;
}

.dish-card::after {
  content: "";
  position: absolute;
  inset: 2rpx;
  border-radius: 44rpx;
  border: 1px solid var(--menu-card-border-soft);
  pointer-events: none;
}

.dish-card--hover {
  transform: translateY(2rpx) scale(0.988);
  box-shadow: 0 8rpx 20rpx rgba(255, 149, 0, 0.12);
  border-color: rgba(255, 255, 255, 0.65);
}

.dish-card--expanded {
  transform: translateY(-2rpx);
  box-shadow: var(--glass-shadow), 0 12rpx 30rpx rgba(255, 149, 0, 0.14);
}

.dish-header {
  padding: 20rpx 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: background 0.2s ease;
}

.dish-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-right: 24rpx;
}

.dish-name-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
}

.dish-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-main);
  line-height: 1.25;
  word-break: break-word;
}

.dish-price {
  flex-shrink: 0;
  font-size: 28rpx;
  font-weight: 700;
  color: #cf6a00;
}

.dish-brief {
  font-size: 26rpx;
  color: var(--menu-accent);
  font-weight: 600;
}

.dish-brief-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 4rpx;
}

.dish-category-tag {
  font-size: 20rpx;
  color: var(--menu-muted);
  background: rgba(255, 255, 255, 0.85);
  border: 2rpx solid rgba(255, 159, 10, 0.35);
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(255, 159, 10, 0.1);
}

/* 底部：左侧「点击卡片查看菜品介绍」+ 右侧数量选择器 */
.dish-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 28rpx 16rpx;
  border-top: 1px dashed rgba(255, 255, 255, 0.6);
  margin: 0;
}

.dish-hint {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 0;
  transition: background 0.2s ease;
}

.dish-hint-text {
  font-size: 24rpx;
  color: #8E8E93;
}

.dish-arrow {
  transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.dish-arrow--expanded {
  transform: rotate(180deg);
}

.dish-detail {
  padding: 0 28rpx 20rpx;
  animation: fadeIn 0.3s ease;
}

.dish-order-row {
  flex-shrink: 0;
  padding: 0;
  margin: 0;
  border-top: none;
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.order-stepper {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.order-btn {
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

.order-btn--minus {
  color: #8f5200;
  background: rgba(255, 159, 10, 0.14);
  border: 1px solid rgba(255, 159, 10, 0.3);
}

.order-btn--plus {
  color: #ffffff;
  background: linear-gradient(135deg, #ff9f0a 0%, #ff7a00 100%);
  border: 1px solid rgba(255, 122, 0, 0.35);
}

.order-count {
  min-width: 28rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-main);
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(-10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes chefBounce {
  0% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(-4rpx) rotate(-4deg); }
  100% { transform: translateY(0) rotate(0deg); }
}

.detail-block {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(18px) saturate(130%);
  -webkit-backdrop-filter: blur(18px) saturate(130%);
  border-radius: 32rpx;
  padding: 14rpx 18rpx;
  margin-top: 8rpx;
  border: 1px solid rgba(255, 255, 255, 0.62);
}

.detail-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--menu-muted);
  margin-bottom: 4rpx;
  display: flex;
  align-items: center;
}

.detail-text {
  font-size: 26rpx;
  color: var(--text-main);
  line-height: 1.32;
}

.detail-text--select {
  user-select: text;
}

.ingredients-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.ingredient-pill {
  background: rgba(255, 159, 10, 0.12);
  color: #8f5200;
  font-size: 24rpx;
  font-weight: 500;
  padding: 6rpx 14rpx;
  border-radius: 24rpx;
  border: 1px solid rgba(255, 159, 10, 0.28);
  box-shadow: 0 2rpx 6rpx rgba(255, 149, 0, 0.08);
}

.options-groups {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.option-group {
  background: rgba(255, 255, 255, 0.45);
  border: 1px solid rgba(255, 255, 255, 0.55);
  border-radius: 24rpx;
  padding: 10rpx 12rpx;
}

.option-group__title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 6rpx;
}

.options-choices {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
}

.option-pill {
  background: rgba(52, 199, 89, 0.12);
  border: 1px solid rgba(52, 199, 89, 0.3);
  color: #1f7a3c;
  font-size: 22rpx;
  padding: 4rpx 10rpx;
  border-radius: 18rpx;
}

.detail-empty {
  text-align: center;
  padding: 10rpx 0 0;
  font-size: 26rpx;
  color: var(--text-sub);
}

.order-summary {
  margin: 8rpx 0 16rpx;
  padding: 18rpx 24rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1px solid rgba(255, 255, 255, 0.72);
  box-shadow: var(--menu-card-shadow);
}

.order-summary__head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-summary__title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
}

.order-summary__actions {
  display: flex;
  gap: 18rpx;
}

.order-summary__link {
  font-size: 24rpx;
  color: #0a84ff;
}

.order-summary__link--danger {
  color: #d64545;
}

.order-summary__meta {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: var(--text-sub);
}

/* 点单汇总栏：固定在视口底部，无需下滑即可看到 */
.order-summary-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 28rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  background-image: var(--glass-noise);
  backdrop-filter: blur(40px) saturate(150%);
  -webkit-backdrop-filter: blur(40px) saturate(150%);
  border-top: 1px solid rgba(255, 255, 255, 0.7);
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.08);
}

.order-summary-bar--fixed {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 9999;
}

.order-summary-bar__main {
  flex: 1;
  min-width: 0;
  padding-right: 24rpx;
}

.order-summary-bar__title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
}

.order-summary-bar__meta {
  display: block;
  margin-top: 6rpx;
  font-size: 26rpx;
  color: var(--text-sub);
}

.order-summary-bar__hint {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--menu-muted);
}

.order-summary-bar__actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.order-summary-bar__link {
  font-size: 26rpx;
  color: #0a84ff;
}

.order-summary-bar__link--danger {
  color: #d64545;
}

.order-summary-bar__btn-retake {
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #ff9f0a 0%, #ff7a00 100%);
  border-radius: 32rpx;
}

/* 点击点单汇总展开的清单浮层 */
.order-detail-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.order-detail-panel {
  width: 100%;
  height: 70vh;
  max-height: 70vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.12);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.order-detail-panel__head {
  flex-shrink: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1px solid rgba(0, 0, 0, 0.06);
}

.order-detail-panel__title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-main);
}

.order-detail-panel__close {
  font-size: 28rpx;
  color: #0a84ff;
}

/* scroll-view 需明确高度才能滚动，高度 = 面板高度 - 标题栏 */
.order-detail-panel__list {
  flex: 1;
  min-height: 0;
  height: calc(70vh - 120rpx);
  padding: 16rpx 0;
  box-sizing: border-box;
}

.order-detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  transition: background 0.2s ease;
}

.order-detail-item__name {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-main);
  margin-right: 24rpx;
}

.order-detail-item__right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.order-detail-item__price {
  font-size: 28rpx;
  font-weight: 600;
  color: #cf6a00;
}

.order-detail-item__stepper {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.order-detail-item__btn {
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

.order-detail-item__btn--minus {
  color: #8f5200;
  background: rgba(255, 159, 10, 0.14);
  border: 1px solid rgba(255, 159, 10, 0.3);
}

.order-detail-item__btn--plus {
  color: #ffffff;
  background: linear-gradient(135deg, #ff9f0a 0%, #ff7a00 100%);
  border: 1px solid rgba(255, 122, 0, 0.35);
}

.order-detail-item__count-num {
  min-width: 28rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-main);
}

.bottom-action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background-color: rgba(242, 242, 247, 0.4);
  background-image: var(--glass-noise);
  backdrop-filter: blur(40px) saturate(150%);
  -webkit-backdrop-filter: blur(40px) saturate(150%);
  border-top: 1px solid rgba(255, 255, 255, 0.4);
  z-index: 100;
}

.btn-primary {
  height: 96rpx;
  background: var(--color-primary);
  color: #ffffff;
  border-radius: 48rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 12rpx 32rpx rgba(255, 149, 0, 0.25);
  transition:
    transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1),
    box-shadow 0.3s ease;
}
